
1、转发到目标含url

        listen 443 ssl;
        server_name sj.yematech.cn nbd.yematech.cn ym-nbd.yematech.cn qingju-nbd.yematech.cn sailing-nbd.yematech.cn;
        #ssl_certificate /etc/nginx/ssl/bd.yematech.cn.pem;
        #ssl_certificate_key /etc/nginx/ssl/bd.yematech.cn.key;

        ssl_certificate /etc/nginx/ssl/yematech.cn/fullchain.pem;
        ssl_certificate_key /etc/nginx/ssl/yematech.cn/key.pem;

        client_max_body_size 0;


        location / {
                proxy_pass http://192.168.0.23:5012;
                proxy_set_header Host $host;
                proxy_set_header X-Real-IP $remote_addr;
                proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                proxy_set_header X-Forwarded-Proto $scheme;

                proxy_redirect off;

        }
